    <string name="setup_permission_title">GRANT ACCESS</string>
    <string name="setup_permission_body">Tap below to grant Mixer (1) access to Shizuku.</string>
    <string name="setup_permission_button">GRANT PERMISSION</string>
    <string name="setup_permission_pending">Status: ⚠ Pending</string>
    <string name="setup_permission_granted">Status: ✓ Granted</string>

